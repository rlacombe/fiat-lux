# --- LLM Engine (choose one) ---

# Option 1: LM Studio (local, free)
FRESNEL_BASE_URL=http://localhost:1234/v1
FRESNEL_API_KEY=lm-studio
FRESNEL_MODEL=qwen2.5-7b-instruct

# Option 2: OpenRouter (cheap, any model)
# FRESNEL_BASE_URL=https://openrouter.ai/api/v1
# FRESNEL_API_KEY=sk-or-...
# FRESNEL_MODEL=anthropic/claude-3-haiku

# Option 3: OpenAI
# FRESNEL_BASE_URL=https://api.openai.com/v1
# FRESNEL_API_KEY=sk-...
# FRESNEL_MODEL=gpt-4o-mini

# --- Engine mode ---
# "llm" = lightweight OpenAI-compatible API (default, fast)
# "agent-sdk" = Claude Agent SDK (slower, full Claude Code features)
FRESNEL_ENGINE=llm

# --- Agent SDK (only needed if FRESNEL_ENGINE=agent-sdk) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Hue Bridge ---
# Managed by Fresnel. Run `fresnel setup` to pair.
# Config stored in ~/.config/fresnel/hue.json
